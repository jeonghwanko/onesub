{
  "name": "@onesub/server",
  "version": "0.12.0",
  "description": "Server-side receipt validation middleware for react-native-iap. Apple StoreKit 2 + Google Play Billing. One line.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "sql"
  ],
  "scripts": {
    "build": "npm run build:types && npm run build:bundle",
    "build:types": "tsc --emitDeclarationOnly",
    "build:bundle": "tsup",
    "dev": "tsc --watch",
    "size": "size-limit",
    "start": "node dist/index.js"
  },
  "keywords": [
    "react-native-iap",
    "in-app-purchase",
    "receipt-validation",
    "storekit",
    "storekit2",
    "google-play-billing",
    "apple",
    "google",
    "subscription",
    "iap",
    "express",
    "middleware",
    "webhook",
    "server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jeonghwanko/onesub.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/jeonghwanko/onesub",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@onesub/shared": "0.7.5",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.7.0",
    "bullmq": ">=5.0.0",
    "express": "^4.17.0 || ^5.0.0",
    "ioredis": ">=5.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@size-limit/file": "^11.1.6",
    "@types/express": "^5.0.6",
    "@types/ioredis-mock": "^8.2.5",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.20.0",
    "express": "^5.2.1",
    "ioredis-mock": "^8.9.0",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
