{
  "name": "onesub",
  "version": "0.1.0",
  "description": "One subscription. That's it. React Native SDK for in-app subscriptions.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "expo",
    "subscription",
    "in-app-purchase",
    "paywall",
    "iap"
  ],
  "license": "MIT",
  "dependencies": {
    "@onesub/shared": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-iap": ">=12.0.0",
    "expo-in-app-purchases": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-iap": {
      "optional": true
    },
    "expo-in-app-purchases": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.7.0"
  }
}
